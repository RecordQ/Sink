# IMPORTANT: Never commit real credentials to git
# Use strong random tokens for production

NUXT_PUBLIC_PREVIEW_MODE=false
NUXT_PUBLIC_SLUG_DEFAULT_LENGTH=5

# Generate a secure random token (min 32 characters recommended)
NUXT_SITE_TOKEN=your-secure-random-token-here

NUXT_REDIRECT_STATUS_CODE=308
NUXT_LINK_CACHE_TTL=60
NUXT_REDIRECT_WITH_QUERY=false
NUXT_HOME_URL=""

# Cloudflare credentials - get these from Cloudflare dashboard
NUXT_CF_ACCOUNT_ID=your-cloudflare-account-id
NUXT_CF_API_TOKEN=your-cloudflare-api-token

# Analytics
NUXT_DATASET=urlify

# AI Settings (optional)
NUXT_AI_MODEL="@cf/meta/llama-3.1-8b-instruct"
NUXT_AI_PROMPT="You are a URL shortening assistant......"
